prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: libstrop
Description: A library for common std::string operations
URL: https://github.com/nicmcd/libstrop
Version: 0.1.0
Requires: libprim
Libs: -L${libdir} -lstrop 
Cflags: -I${includedir}
